{
  "name": "vue-electron-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "vue-tsc -b && vite build && electron-builder",
    "electron:preview": "electron .",
    "clean": "rimraf node_modules dist"
  },
  "dependencies": {
    "@types/three": "^0.183.1",
    "axios": "^1.13.6",
    "chart.js": "^4.5.1",
    "ethers": "^6.16.0",
    "glass-studio-ui-pro": "^1.1.11",
    "gsap": "^3.14.2",
    "html2pdf.js": "^0.14.0",
    "lucide-vue-next": "^1.0.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.5.207",
    "quill": "^2.0.3",
    "socket.io-client": "^4.8.3",
    "three": "^0.183.2",
    "vue": "^3.5.25",
    "vue-chartjs": "^5.3.3",
    "vue-i18n": "^11.3.0",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "sass-embedded": "^1.99.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.1.5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.vue-electron-app",
    "productName": "Vue Electron App",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
